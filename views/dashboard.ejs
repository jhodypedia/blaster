<script>
const socket = io();
let ST = { total: 0, sent: 0, failed: 0, skip: 0 };
let rowCount = 0; let selectedFile = null;
const alertTimers = {}; let _modalCb = null;
let currentModalSessionId = null; let activeModalMethod = 'qr';

// Simpan data awal template yang dipasok oleh EJS saat boot pertama
const initialTemplatesFromServer = <%- JSON.stringify(initialTemplates) %>;

document.addEventListener('DOMContentLoaded', () => {
  lucide.createIcons();
  setupUIEventListeners();
  renderTemplates(initialTemplatesFromServer);
});

async function withLoading(asyncFn) {
  const loader = document.getElementById('global-loader');
  const ctrls = document.querySelectorAll('button, input, select, textarea');
  loader.classList.remove('hidden'); loader.classList.add('flex');
  setTimeout(() => loader.classList.add('opacity-100'), 5);
  ctrls.forEach(c => c.disabled = true);
  try { await asyncFn(); } catch(e) { console.error(e); } finally {
    loader.classList.remove('opacity-100');
    setTimeout(() => { loader.classList.remove('flex'); loader.classList.add('hidden'); }, 200);
    ctrls.forEach(c => c.disabled = false);
    if (ST.total > 0 && (ST.sent + ST.failed + ST.skip < ST.total)) {
      document.getElementById('btnBlast').disabled = false;
    }
  }
}

// ══════════════════════════════════════
// DYNAMIC MULTI-SESSION DRIVER
// ══════════════════════════════════════
async function createNewDeviceSession() {
  const res = await api('/api/create-session', 'POST');
  if(res.success) {
    await fetchAndRenderDevices();
    openConnectWizard(res.sessionId);
  }
}

async function fetchAndRenderDevices() {
  const devices = await api('/api/wa-sessions');
  const grid = document.getElementById('devices-grid');
  grid.innerHTML = '';
  if(!devices.length) {
    grid.innerHTML = `<div class="col-span-full text-center py-12 text-panel-muted bg-white border rounded-2xl"><p class="text-xs font-medium">Belum ada infrastruktur cluster session terdaftar.</p></div>`;
    return;
  }
  devices.forEach(d => {
    const card = document.createElement('div');
    card.className = "bg-white border rounded-2xl p-5 shadow-sm space-y-4 flex flex-col justify-between";
    const dotCls = d.connected ? 'bg-brand-500 shadow-[0_0_8px_#10b981]' : 'bg-slate-300';
    card.innerHTML = `
      <div class="flex items-center justify-between border-b pb-2">
        <div><h4 class="font-bold text-slate-800 font-mono text-sm uppercase">${d.sessionId}</h4><p class="text-[11px] text-panel-muted font-mono mt-0.5">${d.number || '—'}</p></div>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[11px] font-bold ${d.connected?'bg-brand-50 text-brand-600 border border-brand-200':'bg-slate-50 text-slate-500'}"><span class="w-2 h-2 rounded-full ${dotCls}"></span>${d.connected?'Connected':'Offline'}</span>
      </div>
      <div class="flex gap-2 pt-2">
        ${!d.connected ? `<button onclick="openConnectWizard('${d.sessionId}')" class="flex-1 py-2 border rounded-xl font-bold text-xs bg-slate-50 hover:bg-slate-100 flex items-center justify-center gap-1.5">Tautkan Perangkat</button>` : ''}
        <button onclick="deleteDeviceSession('${d.sessionId}')" class="py-2 px-3 border border-rose-200 text-rose-500 rounded-xl hover:bg-rose-50 transition-all">Hapus Sesi</button>
      </div>
    `;
    grid.appendChild(card);
  });
}

function openConnectWizard(sessionId) {
  currentModalSessionId = sessionId;
  document.getElementById('modal-session-id').textContent = `SESSION ID: ${sessionId}`;
  document.getElementById('modal-qrcode').innerHTML = '';
  document.getElementById('m-pair-box').classList.add('hidden');
  document.getElementById('m-pair-phone').value = '';
  document.getElementById('qr-modal-placeholder').style.display = 'block';
  document.getElementById('qr-modal-placeholder').textContent = 'Menunggu String Matrix Server...';
  
  const m = document.getElementById('connectModal');
  m.classList.remove('hidden'); m.classList.add('flex');
  setTimeout(() => { m.classList.add('opacity-100'); m.querySelector('div').classList.remove('scale-95'); }, 5);
}

function closeConnectModal() {
  const m = document.getElementById('connectModal');
  m.classList.remove('opacity-100'); m.querySelector('div').classList.add('scale-95');
  setTimeout(() => { m.classList.remove('flex'); m.classList.add('hidden'); }, 200);
  currentModalSessionId = null;
  withLoading(fetchAndRenderDevices);
}

function toggleModalMethod(method) {
  activeModalMethod = method;
  const bQr = document.getElementById('m-btn-qr'); const bPair = document.getElementById('m-btn-pairing');
  const pQr = document.getElementById('m-pane-qr'); const pPair = document.getElementById('m-pane-pairing');
  if(method === 'qr') {
    bQr.className = "flex-1 py-2 text-xs font-bold rounded-lg bg-white shadow-sm text-slate-800";
    bPair.className = "flex-1 py-2 text-xs font-semibold rounded-lg text-panel-muted";
    pQr.classList.remove('hidden'); pPair.classList.add('hidden');
  } else {
    bPair.className = "flex-1 py-2 text-xs font-bold rounded-lg bg-white shadow-sm text-slate-800";
    bQr.className = "flex-1 py-2 text-xs font-semibold rounded-lg text-panel-muted";
    pPair.classList.remove('hidden'); pQr.classList.add('hidden');
  }
}

// REQUEST PAIRING CODE DENGAN OVERLOAD INTERNAL BUTTON SPINNER LOADING
async function submitPairingRequest() {
  const phone = document.getElementById('m-pair-phone').value.trim();
  if(!phone) return;

  const btn = document.getElementById('btnSubmitPairing');
  const textLabel = document.getElementById('textSubmitPairing');
  const spinnerLabel = document.getElementById('spinnerSubmitPairing');

  // Lock state tombol pairing & tampilkan spinner loading internal
  btn.disabled = true;
  btn.classList.add('bg-brand-600', 'cursor-not-allowed');
  textLabel.classList.add('hidden');
  spinnerLabel.classList.remove('hidden');
  spinnerLabel.classList.add('flex');

  try {
    const res = await api('/api/request-pairing', 'POST', { sessionId: currentModalSessionId, phone });
    if(res.code) {
      document.getElementById('m-pair-box').classList.remove('hidden');
      document.getElementById('m-pair-code').textContent = res.code;
    } else if (res.error) {
      alert("Error: " + res.error);
    }
  } catch (err) {
    console.error(err);
  } finally {
    // Kembalikan state tombol pairing ke posisi normal
    btn.disabled = false;
    btn.classList.remove('bg-brand-600', 'cursor-not-allowed');
    textLabel.classList.remove('hidden');
    spinnerLabel.classList.add('hidden');
    spinnerLabel.classList.remove('flex');
  }
}

function deleteDeviceSession(sessionId) {
  openModal('Hapus Sesi Perangkat', `Apakah Anda yakin ingin mematikan koneksi dan menghapus folder session ${sessionId}?`, async () => {
    await api('/api/logout', 'POST', { sessionId });
  });
}

// ══════════════════════════════════════
// WEB SOCKET LIVE INTERFACES
// ══════════════════════════════════════
socket.on('wa-qr-update', ({ sessionId, qr }) => {
  if(currentModalSessionId === sessionId && activeModalMethod === 'qr') {
    document.getElementById('qr-modal-placeholder').style.display = 'none';
    const qrDiv = document.getElementById('modal-qrcode'); qrDiv.innerHTML = '';
    new QRCode(qrDiv, { text: qr, width: 180, height: 180, colorDark : "#0f172a", correctLevel : QRCode.CorrectLevel.H });
  }
});
socket.on('wa-instance-status', () => { fetchAndRenderDevices(); });
socket.on('wa-instance-deleted', () => { fetchAndRenderDevices(); });

socket.on('blast-ready', ({ total }) => {
  ST = { total, sent: 0, failed: 0, skip: 0 }; updateStats(); updateProgress();
  document.getElementById('btnBlast').disabled = false;
  showAlert('alertKampanye', `${total} kontak termuat ke antrean.`, 'success');
});
socket.on('blast-started', () => {
  document.getElementById('btnBlast').classList.add('hidden');
  document.getElementById('btnStop').classList.remove('hidden');
  document.getElementById('blastStatusPill').innerHTML = 'Running';
});
socket.on('blast-update', ({ id, phone_number, status }) => {
  addLogRow(id, phone_number, status);
  if (status === 'sent') ST.sent++;
  else if (status === 'failed') ST.failed++;
  else if (status === 'not_registered') ST.skip++;
  updateStats(); updateProgress();
});
socket.on('blast-finished', () => {
  document.getElementById('btnBlast').classList.remove('hidden');
  document.getElementById('btnStop').classList.add('hidden');
  document.getElementById('btnBlast').disabled = true;
  document.getElementById('blastStatusPill').innerHTML = 'Selesai';
});
socket.on('blast-reset', () => {
  ST = { total: 0, sent: 0, failed: 0, skip: 0 }; updateStats(); updateProgress();
  document.getElementById('logBody').innerHTML = '<tr><td colspan="4" class="py-12 text-center text-panel-muted font-medium">Log stream kosong. Silakan unggah database.</td></tr>';
  document.getElementById('btnBlast').disabled = true;
  document.getElementById('blastStatusPill').innerHTML = 'Idle';
});
socket.on('terminal-log', ({ ts, msg, type }) => {
  const t = document.getElementById('terminal'); const el = document.createElement('div'); el.className = 'flex gap-2';
  const colors = { ok: 'text-emerald-400', err: 'text-rose-400', warn: 'text-amber-400', info: 'text-slate-400' };
  el.innerHTML = `<span class="text-slate-500 select-none">${ts}</span><span class="${colors[type]||'text-slate-300'}">${esc(msg)}</span>`;
  t.appendChild(el); t.scrollTop = t.scrollHeight;
});

// SPA SINGLE PAGE APPLICATION CLIENT-SIDE ROUTER ENGINE
function nav(el, name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.className = 'nav-item flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-panel-muted border border-transparent transition-all');
  document.getElementById('page-' + name).classList.add('active');
  el.className = 'nav-item flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-brand-600 border border-transparent transition-all bg-brand-50';
  if(name === 'koneksi') withLoading(fetchAndRenderDevices);
  closeSidebar();
}

// TEMPLATE LOGIC MANAGERS
function renderTemplates(data) {
  const list = document.getElementById('templateList');
  document.getElementById('tplCount').textContent = data.length + ' Item';
  if (!data.length) { list.innerHTML = '<p class="text-xs text-center text-panel-muted py-8">Belum ada template.</p>'; return; }
  list.innerHTML = data.map(t => `
    <div class="bg-slate-50 border rounded-xl p-4 flex items-start justify-between gap-4">
      <div class="min-w-0 flex-1"><h4 class="font-bold text-sm text-slate-800 truncate">${esc(t.title)}</h4><p class="text-xs text-panel-muted truncate mt-1">${esc(t.content)}</p></div>
      <div class="flex items-center gap-1 shrink-0">
        <button class="p-1 text-slate-400 hover:text-brand-600" onclick="editTemplate(${t.id},'${b64(t.title)}','${b64(t.content)}')">Edit</button>
        <button class="p-1 text-slate-400 hover:text-rose-600" onclick="deleteTpl(${t.id})">Hapus</button>
      </div>
    </div>
  `).join('');
}
async function loadTemplates() { const data = await api('/api/templates'); renderTemplates(data); }
async function saveTemplate() {
  const id = document.getElementById('editTplId').value; const title = document.getElementById('tplTitle').value.trim(); const content = document.getElementById('tplContent').value.trim();
  if (!title || !content) return showAlert('alertTemplate', 'Semua kolom wajib diisi.', 'error');
  if (id) { await api('/api/templates/' + id, 'PUT', { title, content }); cancelEdit(); } 
  else { await api('/api/templates', 'POST', { title, content }); document.getElementById('tplTitle').value = ''; document.getElementById('tplContent').value = ''; }
  loadTemplates();
}
function editTemplate(id, titleB64, contentB64) {
  document.getElementById('editTplId').value = id; document.getElementById('tplTitle').value = atob(titleB64); document.getElementById('tplContent').value = atob(contentB64);
  document.getElementById('tplFormTitle').textContent = 'Ubah Template'; document.getElementById('btnSaveTpl').textContent = 'Update Template'; document.getElementById('btnCancelEdit').classList.remove('hidden');
}
function cancelEdit() {
  document.getElementById('editTplId').value = ''; document.getElementById('tplTitle').value = ''; document.getElementById('tplContent').value = '';
  document.getElementById('tplFormTitle').textContent = 'Simpan Template Baru'; document.getElementById('btnSaveTpl').textContent = 'Simpan ke Repositori'; document.getElementById('btnCancelEdit').classList.add('hidden');
}
function deleteTpl(id) { openModal('Hapus Template', 'Data template akan dihapus permanen.', async () => { await api('/api/templates/' + id, 'DELETE'); loadTemplates(); }); }
async function loadTemplateOptions() {
  const data = await api('/api/templates'); const sel = document.getElementById('selectTemplate');
  sel.innerHTML = '<option value="">— Silakan Pilih Struktur Template —</option>';
  data.forEach(t => { const o = document.createElement('option'); o.value = t.content; o.textContent = t.title; sel.appendChild(o); });
}

// INTERACTIVE COMPONENT HELPERS
function onFileSelect(e) { selectedFile = e.target.files[0]; document.getElementById('dzFile').textContent = selectedFile ? `Terpilih: ${selectedFile.name}` : ''; }
async function uploadKampanye() {
  const tpl = document.getElementById('selectTemplate').value; const link = document.getElementById('targetLink').value.trim();
  if (!tpl || !link || !selectedFile) return showAlert('alertKampanye', 'Setup parameter data belum lengkap.', 'error');
  const fd = new FormData(); fd.append('file', selectedFile); fd.append('messageTemplate', tpl); fd.append('targetLink', link);
  const res = await fetch('/api/upload-targets', { method: 'POST', body: fd }); const d = await res.json();
  if (d.success) showAlert('alertKampanye', `${d.total} target kontak disinkronkan ke buffer.`, 'success');
}
async function startBlast() { await api('/api/start-blast', 'POST'); }
async function stopBlast() { await api('/api/stop-blast', 'POST'); }
async function resetBlast() { openModal('Reset Antrean', 'Hapus semua data antrean target?', async () => { await api('/api/reset-blast', 'POST'); }); }
async function refreshStats() {
  const d = await api('/api/stats'); ST = { total: Number(d.total)||0, sent: Number(d.sent)||0, failed: Number(d.failed)||0, skip: Number(d.skipped)||0 };
  updateStats(); updateProgress();
  const rows = await api('/api/blast-targets');
  if (rows.length) { document.getElementById('logBody').innerHTML = ''; rowCount = 0; rows.slice().reverse().forEach(r => addLogRow(r.id, r.phone_number, r.status)); }
}
function updateStats() { document.getElementById('s-total').textContent = ST.total; document.getElementById('s-sent').textContent = ST.sent; document.getElementById('s-failed').textContent = ST.failed; document.getElementById('s-skip').textContent = ST.skip; }
function updateProgress() {
  const done = ST.sent + ST.failed + ST.skip; const pct = ST.total ? Math.round(done / ST.total * 100) : 0;
  document.getElementById('progressBar').style.width = pct + '%'; document.getElementById('kProgressBar').style.width = pct + '%';
  document.getElementById('progressText').textContent = `${done} / ${ST.total} Kontak`; document.getElementById('progressPct').textContent = pct + '%';
  document.getElementById('kProgressText').textContent = `${done} / ${ST.total} Kontak`; document.getElementById('kProgressPct').textContent = pct + '%';
}
function addLogRow(id, phone, status) {
  const tbody = document.getElementById('logBody'); const empty = tbody.querySelector('td[colspan]'); if (empty) tbody.innerHTML = ''; rowCount++;
  const map = { sent: ['bg-emerald-50 text-emerald-700', 'TERKIRIM'], failed: ['bg-rose-50 text-rose-700', 'GAGAL'], not_registered: ['bg-amber-50 text-amber-700', 'BUKAN WA'] };
  const [cls, label] = map[status] || ['bg-slate-50 text-slate-600', status.toUpperCase()];
  const tr = document.createElement('tr'); tr.className = 'new-row border-b border-slate-100 hover:bg-slate-50/50 transition-colors';
  tr.innerHTML = `<td class="py-3 px-6 font-mono text-xs text-slate-400">${rowCount}</td><td class="py-3 px-6 font-mono font-medium text-slate-700">${esc(phone)}</td><td class="py-3 px-6"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold ${cls}">${label}</span></td><td class="py-3 px-6 font-mono text-xs text-slate-400">${new Date().toLocaleTimeString('id-ID')}</td>`;
  tbody.insertBefore(tr, tbody.firstChild);
}
function setupUIEventListeners() {
  const dz = document.getElementById('dropzone');
  dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('bg-brand-50/40', 'border-brand-500'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('bg-brand-50/40', 'border-brand-500'));
  dz.addEventListener('drop', e => { e.preventDefault(); dz.classList.remove('bg-brand-50/40', 'border-brand-500'); const f = e.dataTransfer.files[0]; if (f?.name.endsWith('.txt')) { selectedFile = f; document.getElementById('dzFile').textContent = f.name; } });
}
function toggleSidebar() { document.getElementById('sidebar').classList.toggle('-translate-x-full'); document.getElementById('sb-overlay').classList.toggle('hidden'); setTimeout(() => document.getElementById('sb-overlay').classList.toggle('opacity-100'), 5); }
function closeSidebar() { document.getElementById('sidebar').classList.add('-translate-x-full'); document.getElementById('sb-overlay').classList.remove('opacity-100'); setTimeout(() => document.getElementById('sb-overlay').classList.add('hidden'), 300); }
function openModal(title, msg, cb) { document.getElementById('modalTitle').textContent = title; document.getElementById('modalMsg').textContent = msg; const m = document.getElementById('modalOverlay'); m.classList.remove('hidden'); m.classList.add('flex'); setTimeout(() => m.classList.add('opacity-100'), 5); _modalCb = cb; document.getElementById('modalConfirm').onclick = () => { closeModal(); _modalCb && _modalCb(); }; }
function closeModal() { const m = document.getElementById('modalOverlay'); m.classList.remove('opacity-100'); setTimeout(() => { m.classList.remove('flex'); m.classList.add('hidden'); }, 200); _modalCb = null; }
function showAlert(id, msg, type = 'success') {
  const el = document.getElementById(id); if (!el) return; if (alertTimers[id]) clearTimeout(alertTimers[id]); el.textContent = msg; el.className = "p-4 rounded-xl text-xs font-semibold block transition-all duration-300 ";
  if (type === 'success') el.classList.add('bg-emerald-50', 'text-emerald-700', 'border-emerald-200'); else if (type === 'error') el.classList.add('bg-rose-50', 'text-rose-700', 'border-rose-200'); else el.classList.add('bg-amber-50', 'text-amber-700', 'border-amber-200');
  alertTimers[id] = setTimeout(() => el.className = "hidden", 5000);
}
function clearLog() { document.getElementById('logBody').innerHTML = '<tr><td colspan="4" class="py-12 text-center text-panel-muted font-medium">Log stream kosong. Silakan unggah database.</td></tr>'; rowCount = 0; }
async function api(url, method = 'GET', body) {
  const opts = { method, headers: {} }; if (body) { opts.headers['Content-Type'] = 'application/json'; opts.body = JSON.stringify(body); }
  const res = await fetch(url, opts); const data = await res.json(); if (!res.ok) throw new Error(data.error || 'API Error'); return data;
}
function esc(str) { return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function b64(str) { return btoa(unescape(encodeURIComponent(str))); }
function now() { return new Date().toLocaleTimeString('id-ID'); }
</script>
</body>
</html>
